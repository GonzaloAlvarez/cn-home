# cn-home/traefik-lan/dynamic.yml — the routing contract between cn-home and
# every other compose project on kaiser.lan. Each subdomain forwards to a
# 127.0.0.1:<port> binding on the host (because Traefik runs network_mode: host).
#
# ────────────────────────────────────────────────────────────────────────────
# LLM-AGENT EDIT TARGET
# Add a new service by appending a router (HTTPS) + service block below.
# - The router rule MUST be `Host(\`<sub>.${LAN_DOMAIN}\`)` so it works for any
#   apex; envsubst expands ${LAN_DOMAIN} at render-time.
# - The service must bind to a 127.0.0.1:<port> on the kaiser host. If the new
#   service is in cn-observability or another sibling repo, document the port
#   there too.
# - The HTTP catch-all redirect under `http-catchall` is global; new services
#   don't need their own redirect middleware.
# ────────────────────────────────────────────────────────────────────────────
http:
  middlewares:
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true

  routers:
    # Catch-all: any HTTP request hitting Traefik on :80 is bumped to :443.
    http-catchall:
      rule: "HostRegexp(`.+`)"
      entryPoints: [web]
      middlewares: [https-redirect]
      service: noop@internal
      priority: 1

    home:
      rule: "Host(`home.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: home
      tls:
        certResolver: stepca

    grafana:
      rule: "Host(`grafana.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: grafana
      tls:
        certResolver: stepca

    prometheus:
      rule: "Host(`prometheus.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: prometheus
      tls:
        certResolver: stepca

    alertmanager:
      rule: "Host(`alertmanager.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: alertmanager
      tls:
        certResolver: stepca

    loki:
      rule: "Host(`loki.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: loki
      tls:
        certResolver: stepca

    portainer:
      rule: "Host(`portainer.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: portainer
      tls:
        certResolver: stepca

    # cn-bittorrent — torrent core. Backends are 127.0.0.1:<port> on
    # kaiser, published by the ts-torrent sidecar in cn-bittorrent
    # (which owns the network namespace; the qb/*arr suite share it).
    # See ~/dev/cn-bittorrent/docker-compose.yml for the source of truth.
    torrent:
      rule: "Host(`torrent.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: torrent
      tls:
        certResolver: stepca

    sonarr:
      rule: "Host(`sonarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: sonarr
      tls:
        certResolver: stepca

    radarr:
      rule: "Host(`radarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: radarr
      tls:
        certResolver: stepca

    prowlarr:
      rule: "Host(`prowlarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: prowlarr
      tls:
        certResolver: stepca

    lidarr:
      rule: "Host(`lidarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: lidarr
      tls:
        certResolver: stepca

    readarr:
      rule: "Host(`readarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: readarr
      tls:
        certResolver: stepca

    # raidnas (Synology DS418) — DSM web UI. Not on the tailnet; kaiser
    # routes to the appliance directly via pfSense gateway. step-ca
    # terminates TLS so the browser stops yelling about the self-signed
    # cert DSM ships with on :5001.
    raidnas:
      rule: "Host(`raidnas.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: raidnas
      tls:
        certResolver: stepca

    # cn-media — jellyfin. Bare `jellyfin.lan` (NOT `jellyfin.${LAN_DOMAIN}`)
    # to match passwords.lan / raidnas.lan / homeiot.lan TLD-style naming
    # for marquee services. pfSense Host Override points jellyfin.lan at
    # kaiser (10.1.1.140). Backend is the ts-jellyfin sidecar's published
    # 127.0.0.1:8096 on this host.
    jellyfin:
      rule: "Host(`jellyfin.lan`)"
      entryPoints: [websecure]
      service: jellyfin
      tls:
        certResolver: stepca

  services:
    home:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8085"
    grafana:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:3000"
    prometheus:
      loadBalancer:
        servers:
          # Host port 9091 (not 9090) — kaiser's pmproxy occupies 9090.
          - url: "http://127.0.0.1:9091"
    alertmanager:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9093"
    loki:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:3100"
    portainer:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9000"

    torrent:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8080"   # qbittorrent WebUI
    sonarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8989"
    radarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:7878"
    prowlarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9696"
    lidarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8686"
    readarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8787"

    # raidnas DSM HTTP backend. 10.120.26.20:5000 is reachable directly
    # from kaiser via pfSense (the NAS is not on the tailnet). For the
    # tailnet ingress on raidnas.lab.gn.al, see cn-root-docker plan §6
    # (VPS Consul registration via traefik-lab + cn-infra subnet route).
    raidnas:
      loadBalancer:
        servers:
          - url: "http://10.120.26.20:5000"

    # cn-media jellyfin backend — 127.0.0.1:8096 is published on the
    # kaiser host by the ts-jellyfin Tailscale sidecar in cn-media.
    # Tailnet ingress (jellyfin.lab.gn.al) is wired via the cn-media
    # consul-register loop + VPS traefik-lab.
    jellyfin:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8096"
