# cn-home/traefik-lan/dynamic.yml — the routing contract between cn-home and
# every other compose project on kaiser.lan. Each subdomain forwards to a
# 127.0.0.1:<port> binding on the host (because Traefik runs network_mode: host).
#
# ────────────────────────────────────────────────────────────────────────────
# LLM-AGENT EDIT TARGET
# Add a new service by appending a router (HTTPS) + service block below.
# - The router rule MUST be `Host(\`<sub>.${LAN_DOMAIN}\`)` so it works for any
#   apex; envsubst expands ${LAN_DOMAIN} at render-time.
# - The service must bind to a 127.0.0.1:<port> on the kaiser host. If the new
#   service is in cn-observability or another sibling repo, document the port
#   there too.
# - The HTTP catch-all redirect under `http-catchall` is global; new services
#   don't need their own redirect middleware.
# ────────────────────────────────────────────────────────────────────────────
http:
  middlewares:
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true

    # ── Authentik forward-auth (LAN side) ────────────────────────────────
    # Sends every request through the Authentik embedded outpost on
    # neptune.lan before forwarding upstream. The outpost picks the right
    # proxy provider from the request's Host header (configured providers:
    # roms-lan, eventually more). If the user has a valid session, the
    # outpost returns 200 with `Authorization: Basic <b64(user:pass)>` from
    # the user's `romm_username` + `romm_password` group attributes; we
    # forward that header to the upstream, which then sees the request as
    # natively HTTP-Basic authenticated (works for any backend that
    # honors `Authorization: Basic`, e.g. RomM's HybridAuthBackend).
    #
    # `tls.ca: /certs/root_ca.crt` makes traefik-lan trust step-ca for the
    # outbound forward-auth call to auth.neptune.lan (which serves a
    # step-ca leaf). The mount already exists for LEGO_CA_CERTIFICATES.
    authentik-lan:
      forwardAuth:
        address: https://auth.neptune.lan/outpost.goauthentik.io/auth/traefik
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-groups
          - X-authentik-email
          - X-authentik-name
          - X-authentik-uid
          - Authorization
        tls:
          ca: /certs/root_ca.crt

  routers:
    # Catch-all: any HTTP request hitting Traefik on :80 is bumped to :443.
    http-catchall:
      rule: "HostRegexp(`.+`)"
      entryPoints: [web]
      middlewares: [https-redirect]
      service: noop@internal
      priority: 1

    home:
      rule: "Host(`home.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: home
      tls:
        certResolver: stepca

    grafana:
      rule: "Host(`grafana.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: grafana
      tls:
        certResolver: stepca

    prometheus:
      rule: "Host(`prometheus.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: prometheus
      tls:
        certResolver: stepca

    alertmanager:
      rule: "Host(`alertmanager.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: alertmanager
      tls:
        certResolver: stepca

    loki:
      rule: "Host(`loki.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: loki
      tls:
        certResolver: stepca

    portainer:
      rule: "Host(`portainer.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: portainer
      tls:
        certResolver: stepca

    # cn-bittorrent — torrent core. Backends are 127.0.0.1:<port> on
    # kaiser, published by the ts-torrent sidecar in cn-bittorrent
    # (which owns the network namespace; the qb/*arr suite share it).
    # See ~/dev/cn-bittorrent/docker-compose.yml for the source of truth.
    torrent:
      rule: "Host(`torrent.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: torrent
      tls:
        certResolver: stepca

    sonarr:
      rule: "Host(`sonarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: sonarr
      tls:
        certResolver: stepca

    radarr:
      rule: "Host(`radarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: radarr
      tls:
        certResolver: stepca

    prowlarr:
      rule: "Host(`prowlarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: prowlarr
      tls:
        certResolver: stepca

    lidarr:
      rule: "Host(`lidarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: lidarr
      tls:
        certResolver: stepca

    readarr:
      rule: "Host(`readarr.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: readarr
      tls:
        certResolver: stepca

    # raidnas (Synology DS418) — DSM web UI. Not on the tailnet; kaiser
    # routes to the appliance directly via pfSense gateway. step-ca
    # terminates TLS so the browser stops yelling about the self-signed
    # cert DSM ships with on :5001.
    raidnas:
      rule: "Host(`raidnas.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: raidnas
      tls:
        certResolver: stepca

    # cn-media — jellyfin. Lives on kaiser like every other *.kaiser.lan
    # service; cn-home's CoreDNS already wildcards `*.kaiser.lan` →
    # 10.1.1.140, so no pfSense Host Override needed. Backend is the
    # ts-jellyfin sidecar's published 127.0.0.1:8096.
    jellyfin:
      rule: "Host(`jellyfin.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: jellyfin
      tls:
        certResolver: stepca

    # cn-roms — RomM ROM library. Backend is the ts-roms sidecar's
    # published 127.0.0.1:8080. Argosy on Android uses the tailnet path
    # (roms.lab.gn.al) instead — stock Android doesn't trust step-ca.
    #
    # Gated by Authentik via the `authentik-lan` forward-auth middleware:
    # unauthenticated requests get a 302 to auth.neptune.lan; authenticated
    # ones land at RomM with `Authorization: Basic <shared-user>` injected
    # by the outpost. RomM authenticates the Basic header transparently
    # (see /backend/handler/auth/hybrid_auth.py). The shared user lives in
    # Authentik group attributes (media + infra-admins); see
    # cn-authentik/setup-romm-proxy-sso.sh.
    roms:
      rule: "Host(`roms.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      middlewares:
        - authentik-lan
      service: roms
      tls:
        certResolver: stepca

    # cn-fitness — SparkyFitness. Backend is the ts-fitness sidecar's
    # published 127.0.0.1:3004 (frontend nginx, which proxies /api/* to
    # backend on :3010 inside the same netns). Native Android/iOS apps
    # use the tailnet path (fitness.lab.gn.al) — step-ca isn't trusted
    # on stock mobile.
    fitness:
      rule: "Host(`fitness.${LAN_DOMAIN}`)"
      entryPoints: [websecure]
      service: fitness
      tls:
        certResolver: stepca

  services:
    home:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8085"
    grafana:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:3000"
    prometheus:
      loadBalancer:
        servers:
          # Host port 9091 (not 9090) — kaiser's pmproxy occupies 9090.
          - url: "http://127.0.0.1:9091"
    alertmanager:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9093"
    loki:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:3100"
    portainer:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9000"

    torrent:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8080"   # qbittorrent WebUI
    sonarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8989"
    radarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:7878"
    prowlarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:9696"
    lidarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8686"
    readarr:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8787"

    # raidnas DSM HTTP backend. 10.120.26.20:5000 is reachable directly
    # from kaiser via pfSense (the NAS is not on the tailnet). For the
    # tailnet ingress on raidnas.lab.gn.al, see cn-root-docker plan §6
    # (VPS Consul registration via traefik-lab + cn-infra subnet route).
    raidnas:
      loadBalancer:
        servers:
          - url: "http://10.120.26.20:5000"

    # cn-media jellyfin backend — 127.0.0.1:8096 is published on the
    # kaiser host by the ts-jellyfin Tailscale sidecar in cn-media.
    # Tailnet ingress (jellyfin.lab.gn.al) is wired via the cn-media
    # consul-register loop + VPS traefik-lab.
    jellyfin:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8096"

    # cn-roms RomM backend — 127.0.0.1:8083 published by the ts-roms
    # Tailscale sidecar in cn-roms (host port 8083, container port 8080;
    # cn-bittorrent's qbittorrent already owns 127.0.0.1:8080 on this
    # host). Tailnet ingress (roms.lab.gn.al) is wired via cn-roms's
    # consul-register loop + VPS traefik-lab.
    roms:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:8083"

    # cn-fitness SparkyFitness backend — 127.0.0.1:3004 published by the
    # ts-fitness Tailscale sidecar in cn-fitness (host port 3004 → container
    # port 80 on the frontend nginx). Tailnet ingress (fitness.lab.gn.al) is
    # wired via cn-fitness's consul-register loop + VPS traefik-lab.
    fitness:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:3004"
