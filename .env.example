# Step-ca host: must be a hostname, not an IP — step-ca's cert SANs are
# step-ca,pki.lan,pki and Traefik's Lego client verifies the SAN.
PKI_IP=pki.lan

# Email for ACME registration with step-ca
ADMIN_EMAIL=

# LAN zone served by Traefik on this host.
LAN_DOMAIN=kaiser.lan

# IP of the kaiser host on the LAN; the pfSense Domain Override points
# *.${LAN_DOMAIN} at this address.
KAISER_IP=10.1.1.140

# Multi-zone pfSense Domain Overrides — space-separated `zone=IP` pairs.
# Use for ZONE delegations where the target IP runs a DNS server (e.g.
# kaiser runs CoreDNS for *.kaiser.lan).
# Falls back to LAN_DOMAIN/KAISER_IP when unset.
LAN_OVERRIDES="kaiser.lan=10.1.1.140"

# pfSense Host Overrides — space-separated `fqdn=IP` pairs. Use for
# SINGLE-NAME A records where the target IP does NOT run a DNS server
# (e.g. auth.infra.lan → 10.1.1.158, a single Authentik host).
LAN_HOSTS="auth.infra.lan=10.1.1.158"

# SSH target used by ./deploy to rsync the repo and run docker compose.
KAISER_SSH=gonzalo@kaiser.lan
KAISER_SSH_KEY=~/.ssh/gonzalo_main_private_key.pem
KAISER_REMOTE_DIR=/home/gonzalo/dev/cn-home

# Optional: SSL_CERT_DIR used by curl/lego if you ever flip to ACME staging.
SSL_CERT_DIR=/etc/ssl/certs
